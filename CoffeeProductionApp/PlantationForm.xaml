<Window x:Class="CoffeeProductionApp.PlantationForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🌱 Плантация" Height="600" Width="500" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название плантации:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеНазвание" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Страна:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеСтрана" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Регион:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеРегион" Grid.Row="2" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Координаты GPS:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеКоординаты" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Площадь (га):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеПлощадь" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата посадки:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="ПолеДатаПосадки" Grid.Row="5" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Сорт кофе:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокСорт" Grid.Row="6" Grid.Column="1" Margin="5" Height="30">
            <ComboBoxItem Content="Арабика"/>
            <ComboBoxItem Content="Робуста"/>
            <ComboBoxItem Content="Либерика"/>
            <ComboBoxItem Content="Эксцельса"/>
        </ComboBox>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Тип почвы:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокТипПочвы" Grid.Row="7" Grid.Column="1" Margin="5" Height="30" IsEditable="True">
            <ComboBoxItem Content="Вулканическая"/>
            <ComboBoxItem Content="Аллювиальная"/>
            <ComboBoxItem Content="Краснозём"/>
            <ComboBoxItem Content="Латеритная"/>
            <ComboBoxItem Content="Песчаная"/>
            <ComboBoxItem Content="Глинистая"/>
            <ComboBoxItem Content="Суглинистая"/>
            <ComboBoxItem Content="Чернозём"/>
        </ComboBox>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Система полива:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокСистемаПолива" Grid.Row="8" Grid.Column="1" Margin="5" Height="30" IsEditable="True">
            <ComboBoxItem Content="Капельный"/>
            <ComboBoxItem Content="Дождевание"/>
            <ComboBoxItem Content="Бороздковый"/>
            <ComboBoxItem Content="Подпочвенный"/>
            <ComboBoxItem Content="Без полива (богарное)"/>
            <ComboBoxItem Content="Внутрипочвенный"/>
        </ComboBox>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="КнопкаСохранить" Content="💾 Сохранить" Width="120" Height="35" Margin="10" Click="КнопкаСохранить_Click" FontSize="13" Background="LightGreen"/>
            <Button x:Name="КнопкаОтмена" Content="❌ Отмена" Width="120" Height="35" Margin="10" Click="КнопкаОтмена_Click" FontSize="13" Background="LightCoral"/>
        </StackPanel>
    </Grid>
</Window>