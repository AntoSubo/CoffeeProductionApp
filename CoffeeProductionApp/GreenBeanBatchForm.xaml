<Window x:Class="CoffeeProductionApp.GreenBeanBatchForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Партия зеленого зерна" Height="550" Width="500" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер партии:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="txtBatchNumber" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата приемки:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpReceiptDate" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Страна происхождения:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="txtCountry" Grid.Row="2" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Сорт:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="txtVariety" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Вес нетто (кг):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="txtNetWeight" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Влажность (%):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="txtHumidity" Grid.Row="5" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Ячейка хранения:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="cboCell" Grid.Row="6" Grid.Column="1" Margin="5" Height="30" DisplayMemberPath="Value" SelectedValuePath="Key"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Срок хранения (мес):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="txtShelfLife" Grid.Row="7" Grid.Column="1" Margin="5" Height="30"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Margin="10" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Margin="10" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>