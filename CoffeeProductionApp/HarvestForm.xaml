<Window x:Class="CoffeeProductionApp.HarvestForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Урожай" Height="550" Width="500" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Плантация:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокПлантация" Grid.Row="0" Grid.Column="1" Margin="5" Height="30" DisplayMemberPath="Value" SelectedValuePath="Key"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата сбора:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="ПолеДатаСбора" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Метод обработки:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокМетодОбработки" Grid.Row="2" Grid.Column="1" Margin="5" Height="30" IsEditable="True">
            <ComboBoxItem Content="Мытая"/>
            <ComboBoxItem Content="Натуральная"/>
            <ComboBoxItem Content="Медовая"/>
            <ComboBoxItem Content="Анаэробная"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Вес ягод (кг):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеВесЯгод" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Влажность после сушки (%):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеВлажность" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Вес зеленого зерна (кг):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеВесЗерна" Grid.Row="5" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Процент дефектов (%):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеДефекты" Grid.Row="6" Grid.Column="1" Margin="5" Height="30"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="КнопкаСохранить" Content="Сохранить" Width="100" Margin="10" Click="КнопкаСохранить_Click"/>
            <Button x:Name="КнопкаОтмена" Content="Отмена" Width="100" Margin="10" Click="КнопкаОтмена_Click"/>
        </StackPanel>
    </Grid>
</Window>