<Window x:Class="CoffeeProductionApp.WarehouseForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🏭 Склад" Height="350" Width="500" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название склада:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеНазвание" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип склада:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокТип" Grid.Row="1" Grid.Column="1" Margin="5" Height="30">
            <ComboBoxItem Content="Сырьевой"/>
            <ComboBoxItem Content="Готовой продукции"/>
            <ComboBoxItem Content="Упаковочных материалов"/>
        </ComboBox>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Адрес:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеАдрес" Grid.Row="2" Grid.Column="1" Margin="5" Height="30"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="КнопкаСохранить" Content="💾 Сохранить" Width="120" Height="35" Margin="10" Click="КнопкаСохранить_Click" FontSize="13" Background="LightGreen"/>
            <Button x:Name="КнопкаОтмена" Content="❌ Отмена" Width="120" Height="35" Margin="10" Click="КнопкаОтмена_Click" FontSize="13" Background="LightCoral"/>
        </StackPanel>
    </Grid>
</Window>