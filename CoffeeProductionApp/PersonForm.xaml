<Window x:Class="CoffeeProductionApp.PersonForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👤 Сотрудник / Контрагент" Height="450" Width="450" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="ФИО:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеФИО" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Телефон:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеТелефон" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Электронная почта:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеEmail" Grid.Row="2" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата рождения:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="ПолеДатаРождения" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Паспортные данные:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеПаспорт" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="КнопкаСохранить" Content="💾 Сохранить" Width="120" Height="35" Margin="10" Click="КнопкаСохранить_Click" FontSize="13" Background="LightGreen"/>
            <Button x:Name="КнопкаОтмена" Content="❌ Отмена" Width="120" Height="35" Margin="10" Click="КнопкаОтмена_Click" FontSize="13" Background="LightCoral"/>
        </StackPanel>
    </Grid>
</Window>