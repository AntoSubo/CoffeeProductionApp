<Window x:Class="CoffeeProductionApp.CertificateForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📜 Сертификат соответствия" Height="480" Width="550" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер сертификата:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеНомер" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата выдачи:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="ПолеДатаВыдачи" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Срок действия:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="ПолеСрокДействия" Grid.Row="2" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Орган сертификации:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокОрган" Grid.Row="3" Grid.Column="1" Margin="5" Height="30" IsEditable="True">
            <ComboBoxItem Content="Ростест"/>
            <ComboBoxItem Content="SGS"/>
            <ComboBoxItem Content="Eurofins"/>
            <ComboBoxItem Content="Bureau Veritas"/>
            <ComboBoxItem Content="TÜV"/>
            <ComboBoxItem Content="Росаккредитация"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Продукция:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокПродукция" Grid.Row="4" Grid.Column="1" Margin="5" Height="30" DisplayMemberPath="Value" SelectedValuePath="Key"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Стандарт:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокСтандарт" Grid.Row="5" Grid.Column="1" Margin="5" Height="30" IsEditable="True">
            <ComboBoxItem Content="ГОСТ Р 51885-2002"/>
            <ComboBoxItem Content="ТР ТС 021/2011"/>
            <ComboBoxItem Content="ISO 22000"/>
            <ComboBoxItem Content="FSSC 22000"/>
            <ComboBoxItem Content="Organic"/>
            <ComboBoxItem Content="Rainforest Alliance"/>
            <ComboBoxItem Content="UTZ"/>
        </ComboBox>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="КнопкаСохранить" Content="💾 Сохранить" Width="120" Height="35" Margin="10" Click="КнопкаСохранить_Click" FontSize="13" Background="LightGreen"/>
            <Button x:Name="КнопкаОтмена" Content="❌ Отмена" Width="120" Height="35" Margin="10" Click="КнопкаОтмена_Click" FontSize="13" Background="LightCoral"/>
        </StackPanel>
    </Grid>
</Window>