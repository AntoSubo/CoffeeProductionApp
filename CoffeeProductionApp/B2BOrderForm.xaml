<Window x:Class="CoffeeProductionApp.B2BOrderForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказ B2B" Height="550" Width="600" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер заказа:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="txtOrderNumber" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата создания:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpCreationDate" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Договор:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="cboContract" Grid.Row="2" Grid.Column="1" Margin="5" Height="30" DisplayMemberPath="Value" SelectedValuePath="Key"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата отгрузки:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpShipmentDate" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Способ доставки:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDeliveryMethod" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Номер ТТН:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="txtTtnNumber" Grid.Row="5" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Статус:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="cboStatus" Grid.Row="6" Grid.Column="1" Margin="5" Height="30">
            <ComboBoxItem Content="Новый"/>
            <ComboBoxItem Content="В работе"/>
            <ComboBoxItem Content="Отгружен"/>
            <ComboBoxItem Content="Доставлен"/>
            <ComboBoxItem Content="Отменён"/>
        </ComboBox>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Позиции заказа:" FontWeight="Bold" VerticalAlignment="Top"/>
        <DataGrid x:Name="dgOrderItems" Grid.Row="7" Grid.Column="1" Margin="5" Height="150" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="150"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <Button x:Name="btnAddItem" Content="Добавить позицию" Width="120" Margin="5" Click="btnAddItem_Click"/>
            <Button x:Name="btnRemoveItem" Content="Удалить позицию" Width="120" Margin="5" Click="btnRemoveItem_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Margin="10" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Margin="10" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>