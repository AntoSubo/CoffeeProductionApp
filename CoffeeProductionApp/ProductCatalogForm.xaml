<Window x:Class="CoffeeProductionApp.ProductCatalogForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📦 Готовая продукция (справочник)" Height="600" Width="550" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Артикул:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеАртикул" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Торговое наименование:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеНаименование" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Сорт:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокСорт" Grid.Row="2" Grid.Column="1" Margin="5" Height="30" IsEditable="True">
            <ComboBoxItem Content="Арабика"/>
            <ComboBoxItem Content="Робуста"/>
            <ComboBoxItem Content="Либерика"/>
            <ComboBoxItem Content="Эксцельса"/>
            <ComboBoxItem Content="Купаж"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Страна происхождения:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокСтрана" Grid.Row="3" Grid.Column="1" Margin="5" Height="30" IsEditable="True">
            <ComboBoxItem Content="Эфиопия"/>
            <ComboBoxItem Content="Колумбия"/>
            <ComboBoxItem Content="Бразилия"/>
            <ComboBoxItem Content="Вьетнам"/>
            <ComboBoxItem Content="Индонезия"/>
            <ComboBoxItem Content="Кения"/>
            <ComboBoxItem Content="Гватемала"/>
            <ComboBoxItem Content="Коста-Рика"/>
            <ComboBoxItem Content="Перу"/>
            <ComboBoxItem Content="Индия"/>
            <ComboBoxItem Content="Уганда"/>
            <ComboBoxItem Content="Танзания"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Высота произрастания (м):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеВысота" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Степень обжарки:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокОбжарка" Grid.Row="5" Grid.Column="1" Margin="5" Height="30">
            <ComboBoxItem Content="Светлая"/>
            <ComboBoxItem Content="Средняя"/>
            <ComboBoxItem Content="Тёмная"/>
            <ComboBoxItem Content="Итальянская"/>
            <ComboBoxItem Content="Французская"/>
        </ComboBox>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Вкусовые ноты:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеВкусовыеНоты" Grid.Row="6" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Тип упаковки:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокУпаковка" Grid.Row="7" Grid.Column="1" Margin="5" Height="30">
            <ComboBoxItem Content="Зерно"/>
            <ComboBoxItem Content="Молотый"/>
            <ComboBoxItem Content="Капсулы"/>
            <ComboBoxItem Content="Дрип-пакеты"/>
            <ComboBoxItem Content="Сублимированный"/>
        </ComboBox>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="КнопкаСохранить" Content="💾 Сохранить" Width="120" Height="35" Margin="10" Click="КнопкаСохранить_Click" FontSize="13" Background="LightGreen"/>
            <Button x:Name="КнопкаОтмена" Content="❌ Отмена" Width="120" Height="35" Margin="10" Click="КнопкаОтмена_Click" FontSize="13" Background="LightCoral"/>
        </StackPanel>
    </Grid>
</Window>