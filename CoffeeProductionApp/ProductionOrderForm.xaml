<Window x:Class="CoffeeProductionApp.ProductionOrderForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Производственный заказ" Height="600" Width="550" WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер заказа:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеНомерЗаказа" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата создания:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="ПолеДатаСоздания" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Партия зеленого зерна:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокПартияЗерна" Grid.Row="2" Grid.Column="1" Margin="5" Height="30" DisplayMemberPath="Value" SelectedValuePath="Key"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Профиль обжарки:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокПрофиль" Grid.Row="3" Grid.Column="1" Margin="5" Height="30" DisplayMemberPath="Value" SelectedValuePath="Key"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Степень обжарки:" FontWeight="Bold" VerticalAlignment="Center"/>
        <ComboBox x:Name="СписокСтепеньОбжарки" Grid.Row="4" Grid.Column="1" Margin="5" Height="30">
            <ComboBoxItem Content="Светлая"/>
            <ComboBoxItem Content="Средняя"/>
            <ComboBoxItem Content="Тёмная"/>
            <ComboBoxItem Content="Итальянская"/>
        </ComboBox>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Целевой вкус:" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеЦелевойВкус" Grid.Row="5" Grid.Column="1" Margin="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Плановая дата выполнения:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="ПолеПлановаяДата" Grid.Row="6" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Плановый вес (кг):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеПлановыйВес" Grid.Row="7" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Фактический вес (кг):" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ПолеФактическийВес" Grid.Row="8" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Дата выполнения:" FontWeight="Bold" VerticalAlignment="Center"/>
        <DatePicker x:Name="ПолеДатаВыполнения" Grid.Row="9" Grid.Column="1" Margin="5" Height="30"/>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="КнопкаСохранить" Content="Сохранить" Width="100" Margin="10" Click="КнопкаСохранить_Click"/>
            <Button x:Name="КнопкаОтмена" Content="Отмена" Width="100" Margin="10" Click="КнопкаОтмена_Click"/>
        </StackPanel>
    </Grid>
</Window>